# Steam Web API key — for the Valve item schema (IEconItems_440/GetSchema).
# Get one at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# backpack.tf API key — for IGetPrices pricing data.
# Get one at https://backpack.tf/developer/apikey/view
BACKPACK_TF_API_KEY=

# LLM provider for the style-reasoning agent — any Pydantic AI "provider:model" string.
# Switching providers needs no code change, just this one value.
#   anthropic:claude-opus-4-8 (default) | anthropic:claude-sonnet-4-6
#   openrouter:anthropic/claude-sonnet-4.6 | openai:gpt-5.2 | ollama:llama3.3
LLM_MODEL=anthropic:claude-opus-4-8

# Generic API key for whichever provider LLM_MODEL names. Alternatively export the
# provider's own var (ANTHROPIC_API_KEY / OPENROUTER_API_KEY / OPENAI_API_KEY).
# Leave blank for local Ollama. Chat is disabled when no key is found.
LLM_API_KEY=

# Only needed for self-hosted or OpenAI-compatible endpoints (vLLM, remote Ollama).
LLM_BASE_URL=

# Cap on model requests per chat turn, so a runaway tool loop can't burn the key.
# A normal loadout turn uses about 8; weaker models flail and need the ceiling.
LLM_MAX_REQUESTS=15
